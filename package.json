{
  "name": "shale",
  "productName": "Shale",
  "version": "0.2.4",
  "description": "Shale Electron foundation",
  "author": "Shale Contributors",
  "main": ".vite/build/main.js",
  "private": true,
  "scripts": {
    "start": "electron-forge start",
    "rebuild:native": "electron-rebuild --force --which-module better-sqlite3",
    "verify:native": "node scripts/verify-electron-native.mjs",
    "ensure:native": "node scripts/ensure-electron-native.mjs",
    "postinstall": "npm run rebuild:native && npm run verify:native",
    "prestart": "npm run ensure:native",
    "prepackage": "npm run ensure:native",
    "premake": "npm run ensure:native",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint --ext .ts,.tsx .",
    "typecheck": "tsc --noEmit",
    "test": "node scripts/run-vitest-in-electron.mjs run",
    "test:watch": "node scripts/run-vitest-in-electron.mjs"
  },
  "keywords": [],
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-deb": "^7.11.2",
    "@electron-forge/maker-rpm": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.2",
    "@electron-forge/plugin-fuses": "^7.11.2",
    "@electron-forge/plugin-vite": "^7.11.2",
    "@electron/fuses": "^1.8.0",
    "@electron/rebuild": "^3.7.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/dompurify": "^3.0.5",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/jsdom": "^28.0.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/turndown": "^5.0.6",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "^43.1.0",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.32.0",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "better-sqlite3": "^12.11.1",
    "dompurify": "^3.4.12",
    "electron-squirrel-startup": "^1.0.1",
    "jsdom": "^29.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rss-parser": "^3.13.0",
    "turndown": "^7.2.4"
  }
}
